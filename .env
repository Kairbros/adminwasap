# ============================================================
# Configuración de Notificaciones por Correo — WA Manager
# ============================================================
#
# INSTRUCCIONES PARA CONFIGURAR GMAIL:
# 1. Ve a: https://myaccount.google.com/security
# 2. Activa "Verificación en dos pasos" (si no la tienes)
# 3. Ve a "Contraseñas de aplicación"
#    (https://myaccount.google.com/apppasswords)
# 4. Crea una contraseña para "Correo" → copia las 16 letras
# 5. Pega el correo en NOTIFY_EMAIL_USER
# 6. Pega la contraseña (sin espacios) en NOTIFY_EMAIL_PASS
# ============================================================

# Correo Gmail desde el que se envían las alertas (el tuyo)
NOTIFY_EMAIL_USER=wilsonfelipen2004@gmail.com

# Contraseña de aplicación Gmail (16 caracteres, SIN espacios)
# Ejemplo: abcdabcdabcdabcd
NOTIFY_EMAIL_PASS=siipooujxotgfqiy

# Correo destinatario que recibirá las alertas
NOTIFY_EMAIL_TO=wilsonfelipen2004@gmail.com

